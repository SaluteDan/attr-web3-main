{
  "name": "attr-web3",
  "version": "3.0.3",
  "private": false,
  "description": "ATTR smart contracts, deployment scripts, and contract verification workers.",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "default": "./dist/src/index.js"
    },
    "./verify": {
      "default": "./bin/verify-contract.cjs"
    }
  },
  "bin": {
    "attr-web3-verify-contract": "bin/verify-contract.cjs"
  },
  "files": [
    "bin/",
    "dist/",
    "contracts/",
    "docs/",
    "scripts/",
    "hardhat.config.ts",
    "foundry.toml",
    "slither.config.json",
    "tsconfig.json",
    "tsconfig.build.json",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "build:symlink": "node scripts/util/build-symlink.js",
    "prepublishOnly": "npm run compile && npm run build",
    "compile": "hardhat compile",
    "test": "hardhat test",
    "test:contracts": "hardhat test test/contracts/**/*.test.ts",
    "test:fuzz": "forge test",
    "coverage": "hardhat coverage",
    "lint:sol": "solhint \"contracts/**/*.sol\"",
    "pack:dry-run": "npm pack --dry-run",
    "verify:contract": "node bin/verify-contract.cjs",
    "check:balance": "hardhat run scripts/check/balance.ts",
    "deploy:token": "hardhat run scripts/deploy/token.ts",
    "deploy:factory": "hardhat run scripts/deploy/factory.ts",
    "deploy:vesting-factory": "hardhat run scripts/deploy/vestingFactory.ts",
    "deploy:membership": "hardhat run scripts/deploy/membershipToken.ts",
    "diagnose:factory": "tsx scripts/diagnose-factory.ts"
  },
  "keywords": [
    "attr",
    "hardhat",
    "solidity",
    "base",
    "verification"
  ],
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@openzeppelin/contracts": "^5.4.0",
    "dotenv": "^16.3.1",
    "hardhat": "^3.4.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.1.6",
    "viem": "^2.40.3"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-verify": "^3.0.17",
    "@nomicfoundation/hardhat-viem": "^3.0.7",
    "@types/node": "^20.4.5",
    "solhint": "^6.2.1",
    "solidity-coverage": "^0.8.17",
    "tsx": "^4.21.0"
  },
  "peerDependencies": {
    "ethers": "^6.0.0"
  },
  "license": "ISC",
  "type": "module"
}
