# Base network RPCs.
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
BASE_MAINNET_RPC_URL=https://mainnet.base.org

# Private key used for deployments and contract operations.
PRIVATE_KEY=your_private_key_here

# Unified Etherscan V2 key used by Hardhat verification.
BASESCAN_API_KEY=your_basescan_api_key

# Deployment addresses.
PLATFORM_TREASURY_ADDRESS=0x...
PAYMENT_RECEIVER=0x...
GOV_PAYMENT_RECEIVER=0x...
ROYALTY_RECEIVER=0x...
FACTORY_CONTRACT_ADDRESS=0x...

# Contract parameters.
ATTR_CAP=1000000000
ATTR_INITIAL_SUPPLY=100000000


MEMBERSHIP_MAX_SUPPLY=10000
MEMBERSHIP_NAME="ATTR ID"
MEMBERSHIP_SYMBOL="ATTR#"
GOV_NAME="Platform Membership"
GOV_SYMBOL="MBR"
GOV_MAX_SUPPLY=5000
GOV_MAX_MINT=1
GOV_ROYALTY_BPS=500
GOV_CONTRACT_URI=ipfs://QmYourMetadataHash
